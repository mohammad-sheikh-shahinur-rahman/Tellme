rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net: Default deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'username', 'displayName', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.uid == request.auth.uid &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 30 &&
             data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 50 &&
             data.createdAt == request.time;
    }

    function isValidLetter(data) {
      return data.keys().hasAll(['toUsername', 'toUserId', 'encryptedContent', 'createdAt']) &&
             data.toUsername is string && data.toUsername.size() <= 30 &&
             data.toUserId is string && data.toUserId.size() <= 128 &&
             data.encryptedContent is string && data.encryptedContent.size() <= 50000 &&
             data.createdAt == request.time &&
             // Optional fields
             (!data.keys().contains('fromUserId') || (data.fromUserId is string && data.fromUserId == request.auth.uid)) &&
             (!data.keys().contains('fromUsername') || data.fromUsername is string) &&
             (!data.keys().contains('templateId') || data.templateId is string) &&
             (!data.keys().contains('fontSize') || data.fontSize is string) &&
             (!data.keys().contains('isRead') || data.isRead is bool) &&
             (!data.keys().contains('attachmentBase64') || (data.attachmentBase64 is string && data.attachmentBase64.size() <= 1000000)) &&
             (!data.keys().contains('voiceBase64') || (data.voiceBase64 is string && data.voiceBase64.size() <= 1500000));
    }

    // --- Main Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && 
                      isValidUserProfile(incoming()) &&
                      incoming().uid == existing().uid &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'username']);
    }

    match /usernames/{username} {
      allow get: if true; // Public check for availability
      allow create: if isSignedIn() && 
                      incoming().uid == request.auth.uid &&
                      exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    match /letters/{letterId} {
      // 8. Secure List Queries: Enforce ownership check on resource.data
      allow list: if isSignedIn() && (resource.data.toUserId == request.auth.uid || resource.data.fromUserId == request.auth.uid);
      allow get: if isSignedIn() && (resource.data.toUserId == request.auth.uid || resource.data.fromUserId == request.auth.uid);
      
      // Anyone can send a letter (anonymous or logged in)
      allow create: if isValidLetter(incoming()) && 
                      exists(/databases/$(database)/documents/users/$(incoming().toUserId));
      
      allow update: if isSignedIn() && 
                      resource.data.toUserId == request.auth.uid &&
                      incoming().diff(existing()).affectedKeys().hasAny(['replyEncryptedContent', 'repliedAt', 'isRead']) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['replyEncryptedContent', 'repliedAt', 'isRead']) &&
                      (!incoming().diff(existing()).affectedKeys().contains('repliedAt') || incoming().repliedAt == request.time);

      allow delete: if isSignedIn() && resource.data.toUserId == request.auth.uid;
    }
  }
}
